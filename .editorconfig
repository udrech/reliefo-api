root = true

[*.cs]
# Core formatting
indent_style = space
indent_size = 4
end_of_line = crlf
charset = utf-8-bom
trim_trailing_whitespace = true
insert_final_newline = true

# SA1200: Using directives must be placed correctly — allow outside namespace (file-scoped)
dotnet_diagnostic.SA1200.severity = none

# SA1309: Field names must not begin with underscore — we use _context etc.
dotnet_diagnostic.SA1309.severity = none

# SA1101: Prefix local calls with this — too noisy for controllers
dotnet_diagnostic.SA1101.severity = none

# SA1600/SA1601/SA1602/SA1604: XML documentation — disabled for internal/private members
dotnet_diagnostic.SA1600.severity = none
dotnet_diagnostic.SA1601.severity = none
dotnet_diagnostic.SA1602.severity = none
dotnet_diagnostic.SA1604.severity = none

# SA1633: File must have header — disabled (no file headers used)
dotnet_diagnostic.SA1633.severity = none

# SA1516: Elements must be separated by blank line
dotnet_diagnostic.SA1516.severity = warning

# SA1210: Using directives must be ordered alphabetically
dotnet_diagnostic.SA1210.severity = warning

# SA1000-SA1058: Spacing and readability
dotnet_diagnostic.SA1000.severity = warning
dotnet_diagnostic.SA1001.severity = warning
dotnet_diagnostic.SA1003.severity = warning
dotnet_diagnostic.SA1025.severity = warning

# SA1300: Element names must begin with upper-case
dotnet_diagnostic.SA1300.severity = warning

# SA1400: Access modifier must be declared (error)
dotnet_diagnostic.SA1400.severity = error

# SA1500/SA1501: Braces on their own lines
dotnet_diagnostic.SA1500.severity = warning
dotnet_diagnostic.SA1501.severity = warning
